<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <intent>
            <action android:name="com.google.android.gms.auth.api.signin.SERVICE" />
        </intent>

        <package android:name="com.google.android.gms" />

        <intent>
            <action android:name="android.intent.action.SENDTO" />

            <data android:scheme="mailto" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinanzaInteligente">
        <activity
            android:name=".BreakdownActivity"
            android:exported="false"
            android:label="Desglose Financiero"
            android:theme="@style/Theme.FinanzaInteligente" />
        <activity
            android:name=".DeudaActivity"
            android:exported="false" />
        <activity
            android:name=".FinancialSetupActivity"
            android:exported="false"
            android:label="@string/title_activity_financial_setup"
            android:theme="@style/Theme.FinanzaInteligente" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.FinanzaInteligente" />
        <activity
            android:name=".AlertsSetupActivity"
            android:exported="false"
            android:label="Configuración de Alertas"
            android:theme="@style/Theme.FinanzaInteligente" />
        <activity
            android:name=".ManageDeudasActivity"
            android:exported="false"
            android:label="Gestionar Deudas"
            android:theme="@style/Theme.FinanzaInteligente" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
